# ReproForge Sentinel environment example
# Copy this file to .env locally. Do not commit real secrets.

APP_NAME=ReproForge Sentinel
APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000

DATABASE_URL=sqlite+aiosqlite:///./reproforge.db
REDIS_URL=redis://localhost:6379/0

# Add real keys locally only when needed
LLM_API_KEY=
AMD_CREDIT_STATUS=pending
AMD_RUNTIME_MODE=mock
