# Frontend API URL embedded at build time
VITE_API_BASE_URL=http://localhost:8000

# Preferred provider path. Gemma 4 requires an existing Fireworks on-demand deployment.
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/<ACCOUNT_ID>/deployments/<DEPLOYMENT_ID>

# Optional hash-linked AMD/ROCm artifact inside the backend container
AMD_PROOF_FILE=/app/artifacts/amd-run.json

# Official Google AI API fallback; used automatically if Fireworks fails.
GEMMA_API_KEY=
GEMMA_MODEL=gemma-4-26b-a4b-it

# Comma-separated frontend origins allowed by FastAPI
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
